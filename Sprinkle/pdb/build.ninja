# build.ninja — Build script for pdb for macOS.
optflags   = -g
progname   = pdb
include ../../tools.ninja
platflags  = -I $host/.. -I $additions
libtwinbeam = ../../Source/Releases/libTwinbeam_macOS.a
objsdir = ./.objs/7703a322-55A9-44ca-b218-eabcf7f87663_$progname
flags = $optflags $macoscflags $platflags

include $host/macbook.ninja

rule link
    command = xcrun ld -macosx_version_min 10.14.0 -lSystem -lc++ -o $out   $
      $libtwinbeam $in

build $progname: link $objsdir/main.o $objsdir/Present2.o $objsdir/mips.o   $
  $objsdir/mzda.o $objsdir/Additions.o $objsdir/Automata.o                  $
  $objsdir/Streams.o $objsdir/Utf8Terminal.o $objsdir/llvmʳᵗ³.o
build $objsdir/Present2.o: cc Present2.cpp
build $objsdir/mips.o: cc mips.cpp
build $objsdir/mzda.o: cc mzda.cpp
build $objsdir/main.o: cc main.cpp
build $objsdir/Additions.o: cc ../../Additions/Additions.cpp
build $objsdir/Automata.o: cc ../../Additions/Automata.cpp
build $objsdir/Streams.o: cc ../../Additions/Streams.cpp
build $objsdir/Utf8Terminal.o: cc ../../Additions/Utf8Terminal.cpp
build $objsdir/llvmʳᵗ³.o: cc ../../Source/llvmʳᵗ³.cpp

default $progname

